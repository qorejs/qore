{
  "name": "@qore/devtools",
  "version": "0.6.0",
  "description": "Qore Framework Developer Tools - Browser DevTools Extension",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./hook": {
      "import": "./dist/hook.js",
      "types": "./dist/hook.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "build:types": "tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build && pnpm run test",
    "publish:npm": "npm publish --access public"
  },
  "keywords": [
    "qore",
    "devtools",
    "debugger",
    "developer-tools",
    "frontend",
    "framework"
  ],
  "author": "Qore Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qore-framework/qore.git",
    "directory": "packages/devtools"
  },
  "homepage": "https://github.com/qore-framework/qore#readme",
  "bugs": {
    "url": "https://github.com/qore-framework/qore/issues"
  },
  "peerDependencies": {
    "@qore/core": "^0.6.0"
  },
  "devDependencies": {
    "@qore/core": "workspace:*",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
